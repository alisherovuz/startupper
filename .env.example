# ---- Telegram ----
BOT_TOKEN=put-your-NEW-token-here
BOT_USERNAME=startupperuzbot
REQUIRED_CHANNELS=@startupper_uz,@startupper_elon
POSTING_CHANNEL=@startupper_elon
ADMIN_IDS=5956268818,6062604329
# Optional: where "new request" notifications go (else admins won't get DMs)
ADMIN_CHAT_ID=

# ---- Database (Railway sets this automatically when you add Postgres) ----
DATABASE_URL=postgresql://user:pass@host:port/dbname

# ---- Webhook ----
# Public URL of THIS Railway service (Settings -> Networking -> Generate Domain)
WEBHOOK_URL=https://your-app.up.railway.app
# Any random string; protects the webhook endpoint
WEBHOOK_SECRET=change-me-to-something-random
